{
  "name": "i-daily",
  "version": "0.2.20",
  "description": "데일리 업무일지 웹앱 (Cloudflare Workers · D1)",
  "author": {
    "name": "minsoo.lee",
    "email": "minsoo.lee@users.noreply.github.com"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/preinpost/i-daily.git"
  },
  "scripts": {
    "dev": "concurrently -n api,web -c cyan,magenta \"wrangler dev --port 8787\" \"vite --config vite.web.config.ts --port 5173\"",
    "dev:api": "wrangler dev --port 8787",
    "dev:ui": "vite --config vite.web.config.ts --port 5173",
    "build": "vite build --config vite.web.config.ts",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test test/*.test.ts",
    "types:worker": "wrangler types",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply i-daily --local",
    "db:migrate:remote": "wrangler d1 migrations apply i-daily --remote",
    "db:create": "wrangler d1 create i-daily"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^5.20260719.1",
    "@tailwindcss/vite": "^4.3.2",
    "@types/node": "^26.1.1",
    "@types/react": "^18.3.31",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^4.7.0",
    "concurrently": "^10.0.3",
    "drizzle-kit": "^0.31.10",
    "miniflare": "^4.20260714.0",
    "tailwindcss": "^4.3.2",
    "tsx": "^4.23.0",
    "typescript": "^7.0.2",
    "wrangler": "^4.112.0"
  },
  "dependencies": {
    "@tiptap/extension-placeholder": "^3.28.0",
    "@tiptap/extension-table": "^3.28.0",
    "@tiptap/extension-table-cell": "^3.28.0",
    "@tiptap/extension-table-header": "^3.28.0",
    "@tiptap/extension-table-row": "^3.28.0",
    "@tiptap/extension-task-item": "^3.28.0",
    "@tiptap/extension-task-list": "^3.28.0",
    "@tiptap/pm": "^3.28.0",
    "@tiptap/react": "^3.28.0",
    "@tiptap/starter-kit": "^3.28.0",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.31",
    "lucide-react": "^1.25.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tiptap-markdown": "^0.9.0"
  }
}
